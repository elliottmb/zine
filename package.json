{
  "name": "tailwind-css-component-library",
  "version": "1.0.0",
  "description": "A Tailwind CSS component library for retro-inspired digital zines.",
  "scripts": {
    "build": "tailwindcss build src/styles.css -o dist/styles.css",
    "watch": "tailwindcss build src/styles.css -o dist/styles.css --watch",
    "start": "npm run build && npm run watch"
  },
  "dependencies": {
    "tailwindcss": "^2.2.19",
    "postcss": "^8.2.15",
    "autoprefixer": "^10.3.7"
  },
  "devDependencies": {
    "concurrently": "^6.0.0"
  },
  "license": "MIT"
}
