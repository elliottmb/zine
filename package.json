{
  "name": "tailwind-css-component-library",
  "version": "1.0.0",
  "description": "A Tailwind CSS component library for retro-inspired digital zines.",
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "watch": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "start": "npm run watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "license": "MIT"
}
